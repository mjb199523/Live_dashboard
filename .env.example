# ──────────────────────────────────────────────────────────────
# Dashboard — Environment Variables
# Copy this file to .env and fill in the values you want.
# ALL keys are OPTIONAL — the dashboard works without any.
# ──────────────────────────────────────────────────────────────

# OpenSky Network — live aircraft tracking
# Register free: https://opensky-network.org/register
# Without it: 100 req/day (unauthenticated); with: 1000 req/day
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# MapTiler — premium dark map tiles
# Free tier (100k tiles/mo): https://www.maptiler.com/
# Without it: uses CARTO Dark Matter tiles (free, no key)
# MAPTILER_KEY=

# NewsAPI — expanded news headlines
# Free tier (100 req/day): https://newsapi.org/
# Without it: uses direct RSS feeds (unlimited, no key)
# NEWSAPI_KEY=

# Ollama — local LLM for news summarization
# Install: https://ollama.ai/
# Without it: summaries are skipped, just headlines shown
# OLLAMA_URL=http://localhost:11434

# Server port (default 3001)
# PORT=3001
